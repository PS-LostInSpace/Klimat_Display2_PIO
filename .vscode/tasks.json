{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OTA: Build + Upload",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/ota-upload.ps1"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "OTA: Upload (Skip Build)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/ota-upload.ps1",
        "-SkipBuild"
      ],
      "problemMatcher": []
    }
  ]
}
